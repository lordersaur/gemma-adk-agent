# OpenAI-compatible API base URL of your llama.cpp server
UNSLOTH_BASE_URL=http://localhost:8080/v1

# Model name — must match the alias your llama.cpp server exposes
# Current setup uses: gemma-4-E4B-it-UD-Q8_K_XL.gguf
GEMMA_MODEL=gemma-4-E4B-it-UD-Q8_K_XL

# Optional API key if your server requires one
UNSLOTH_API_KEY=

# Remote logging — set on remote PCs to forward sessions back to this machine.
# Run the combined proxy+log server: uvicorn api:app --host 0.0.0.0 --port 8079
# Tunnel it: ./cloudflared tunnel --url http://localhost:8079
# Then set both vars to the same tunnel URL:
#   UNSLOTH_BASE_URL=https://<tunnel>.trycloudflare.com/v1
#   LOG_SERVER_URL=https://<tunnel>.trycloudflare.com
# LOG_SERVER_URL=

# ADK session settings
APP_NAME=gemma-adk-agent
