# Unsloth Studio OpenAI-compatible API base URL
# Default port when running locally — check Studio UI for the actual port
UNSLOTH_BASE_URL=http://localhost:5000/v1

# Model ID as shown in Unsloth Studio (HuggingFace repo ID or local alias)
# 4B Q8 / 4-bit options:
#   unsloth/gemma-3-4b-it-unsloth-bnb-4bit   (4-bit, ~3 GB)
#   unsloth/gemma-3-4b-it                     (full precision)
# Larger:
#   unsloth/gemma-3-12b-it-unsloth-bnb-4bit  (4-bit, ~7 GB)
#   unsloth/gemma-3-27b-it-unsloth-bnb-4bit  (4-bit, ~15 GB)
GEMMA_MODEL=unsloth/gemma-3-4b-it-unsloth-bnb-4bit

# ADK session settings
APP_NAME=gemma-adk-agent
