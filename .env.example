# OpenAI-compatible API base URL of your llama.cpp server
UNSLOTH_BASE_URL=http://localhost:8080/v1

# Model name — must match the alias your llama.cpp server exposes
# Current setup uses: gemma-4-E4B-it-UD-Q8_K_XL.gguf
GEMMA_MODEL=gemma-4-E4B-it-UD-Q8_K_XL

# Optional API key if your server requires one
UNSLOTH_API_KEY=

# ADK session settings
APP_NAME=gemma-adk-agent
